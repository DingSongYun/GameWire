# ========== 数据库 ==========
# 本地开发使用 localhost，Docker Compose 中改为 postgres
DATABASE_URL=postgresql+asyncpg://gamewire:gamewire_dev@postgres:5432/gamewire

# ========== Redis ==========
# 本地开发使用 localhost，Docker Compose 中改为 redis
REDIS_URL=redis://redis:6379/0

# ========== JWT 认证 ==========
JWT_SECRET=change-me-to-a-secure-random-string
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ========== OpenAI / LLM ==========
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini
LLM_DAILY_TOKEN_BUDGET=1000000

# ========== Twitter/X API ==========
TWITTER_BEARER_TOKEN=your-twitter-bearer-token

# ========== Reddit API ==========
REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_CLIENT_SECRET=your-reddit-client-secret
REDDIT_USER_AGENT=GameWire/0.1.0

# ========== GitHub API ==========
GITHUB_TOKEN=your-github-personal-access-token

# ========== 应用配置 ==========
APP_NAME=GameWire
APP_ENV=development
CORS_ORIGINS=http://localhost:5173
DEFAULT_ADMIN_EMAIL=admin@gamewire.local
DEFAULT_ADMIN_PASSWORD=change-me-on-first-login